# =============================================================================
# ClimateCred — environment variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.
# =============================================================================

# ---------------------------------------------------------------------------
# Next.js (frontend + API proxy)
# ---------------------------------------------------------------------------

# URL of the running FastAPI backend.
# In development this is usually http://localhost:8000.
# In production set this to wherever you deploy the FastAPI server.
FASTAPI_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# FastAPI / Python backend
# Create a .env file inside the /backend directory with these values,
# or export them in your shell before running uvicorn.
# ---------------------------------------------------------------------------

# Hugging Face token — needed to download the RCSCode/Climate_Cred model.
# Get yours at https://huggingface.co/settings/tokens
HF_TOKEN=hf_...

# Currents API key — https://currentsapi.services
C_API_TOKEN=...

# GNews API key — https://gnews.io
GNEWS_API_KEY=...

# Exa API key — https://exa.ai
EXA_API_KEY=...
F_CRAWL_KEY=...
# Optional: the origin of your deployed frontend (used by the CORS allow-list).
# Leave blank in development.
FRONTEND_URL=
